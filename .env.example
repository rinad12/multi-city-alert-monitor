# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN=123456789:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Target chat/channel/group ID (use a negative number for channels, e.g. -100...)
CHANNEL_ID=-1001234567890

# ── Alert Filter ──────────────────────────────────────────────────────────────
# Comma-separated list of city names in Hebrew exactly as they appear in the
# Pikud HaOref API (no spaces around commas).
# Example: אשקלון,אשדוד,שדרות
TARGET_CITIES_HEBREW=אשקלון,אשדוד,שדרות

# ── Localisation ───────────────────────────────────────────────────────────────
# Target language for bot messages (BCP-47 code: ru, en, de, fr, uk, he, …)
# Messages are authored in Russian and translated via LibreTranslate.
# Set to "ru" (or leave empty) to skip translation entirely.
TARGET_LANG=en

# URL of your LibreTranslate instance (self-hosted or public)
LIBRE_TRANSLATE_URL=http://localhost:5000

# API key — leave empty if your instance does not require one
LIBRE_TRANSLATE_KEY=

# Path to the persistent city list file (default: cities.json next to index.js)
# CITIES_FILE_PATH=/data/cities.json

# ── Tunable constants (optional, shown with defaults) ─────────────────────────
# POLL_INTERVAL_MS=2000
# BACKOFF_INTERVAL_MS=5000
# BACKOFF_THRESHOLD=3
# DEDUP_TTL_MS=600000
# SEND_MAX_RETRIES=3

# Set to "true" to log full alert objects for debugging
# DEBUG=false
